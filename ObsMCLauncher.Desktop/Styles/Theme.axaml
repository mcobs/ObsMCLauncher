<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <SolidColorBrush x:Key="BrandBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#059669"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#10B981"/>

    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#252525"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#383838"/>

    <SolidColorBrush x:Key="TextBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#707070"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#2A2A2A"/>

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#F0F0F0"/>

    <SolidColorBrush x:Key="GlassmorphismBackgroundBrush" Color="#252525" Opacity="0.88"/>
    <SolidColorBrush x:Key="GlassmorphismBorderBrush" Color="#FFFFFF" Opacity="0.5"/>

    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerDarkBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6"/>

    <SolidColorBrush x:Key="SystemControlBackgroundBaseHighBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#252525"/>
    <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="#383838"/>
    <SolidColorBrush x:Key="SystemControlBackgroundBaseMediumBrush" Color="#2D2D2D"/>

    <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#3A3A3A"/>

    <Color x:Key="SystemAccentColor">#10B981</Color>

    <Color x:Key="SystemAltHighColor">#1A1A1A</Color>
    <Color x:Key="SystemAltLowColor">#1A1A1A</Color>
    <Color x:Key="SystemBaseHighColor">#F0F0F0</Color>
    <Color x:Key="SystemBaseMediumColor">#707070</Color>
  </Styles.Resources>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="ScrollBar:vertical /template/ Border#RootBorder">
    <Setter Property="Width" Value="6"/>
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="ScrollBar:horizontal /template/ Border#RootBorder">
    <Setter Property="Height" Value="6"/>
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="ScrollBar:vertical /template/ RepeatButton#VerticalSmallDecrease">
    <Setter Property="Height" Value="0"/>
  </Style>

  <Style Selector="ScrollBar:vertical /template/ RepeatButton#VerticalSmallIncrease">
    <Setter Property="Height" Value="0"/>
  </Style>

  <Style Selector="ScrollBar:horizontal /template/ RepeatButton#HorizontalSmallDecrease">
    <Setter Property="Width" Value="0"/>
  </Style>

  <Style Selector="ScrollBar:horizontal /template/ RepeatButton#HorizontalSmallIncrease">
    <Setter Property="Width" Value="0"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#50FFFFFF"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="MinHeight" Value="30"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="#80FFFFFF"/>
  </Style>

  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
    <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Height" Value="6"/>
  </Style>

  <Style Selector="ProgressBar /template/ Border#ProgressBarTrack">
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="0,4"/>
  </Style>

</Styles>
