<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ObsMCLauncher.Desktop.ViewModels"
             xmlns:converters="using:ObsMCLauncher.Desktop.Converters"
             x:Class="ObsMCLauncher.Desktop.Views.ResourcesView"
             x:DataType="vm:ResourcesViewModel"
             x:Name="Root">

  <Grid RowDefinitions="Auto,Auto,*" Margin="20">

    <StackPanel Grid.Row="0" Spacing="4" IsVisible="{Binding IsListVisible}">
      <TextBlock Text="资源中心" FontSize="22" FontWeight="Bold" />
      <TextBlock Text="下载 MOD、材质包、光影、数据包和整合包" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" />
    </StackPanel>

    <Border Grid.Row="1" Margin="0,0,0,10" CornerRadius="10"
            Background="{DynamicResource SurfaceBrush}" Padding="12"
            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
            IsVisible="{Binding IsListVisible}">
      <StackPanel Spacing="8">

        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" Margin="0,0,12,0">
            <RadioButton Content="MOD" GroupName="resType"
                         IsChecked="{Binding CurrentResourceType, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Mods}"
                         Command="{Binding ChangeTypeCommand}" CommandParameter="Mods" FontSize="12" Padding="8,4"/>
            <RadioButton Content="材质包" GroupName="resType"
                         IsChecked="{Binding CurrentResourceType, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Textures}"
                         Command="{Binding ChangeTypeCommand}" CommandParameter="Textures" FontSize="12" Padding="8,4"/>
            <RadioButton Content="光影" GroupName="resType"
                         IsChecked="{Binding CurrentResourceType, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Shaders}"
                         Command="{Binding ChangeTypeCommand}" CommandParameter="Shaders" FontSize="12" Padding="8,4"/>
            <RadioButton Content="数据包" GroupName="resType"
                         IsChecked="{Binding CurrentResourceType, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Datapacks}"
                         Command="{Binding ChangeTypeCommand}" CommandParameter="Datapacks" FontSize="12" Padding="8,4"/>
            <RadioButton Content="整合包" GroupName="resType"
                         IsChecked="{Binding CurrentResourceType, Converter={x:Static converters:StringEqualsConverter.Instance}, ConverterParameter=Modpacks}"
                         Command="{Binding ChangeTypeCommand}" CommandParameter="Modpacks" FontSize="12" Padding="8,4"/>
          </StackPanel>

          <TextBox Grid.Column="1" Text="{Binding Query}" Watermark="搜索资源..." FontSize="12" Margin="0,0,12,0"/>

          <Button Grid.Column="2" Content="搜索" Classes="accent" FontSize="12"
                  Command="{Binding SearchCommand}" IsEnabled="{Binding !IsLoading}"
                  Padding="16,5" />
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
          <ComboBox Grid.Column="0" Width="110" FontSize="12"
                    SelectedIndex="{Binding CurrentSourceIndex}">
            <ComboBoxItem Content="CurseForge" />
            <ComboBoxItem Content="Modrinth" />
            <ComboBoxItem Content="全部" />
          </ComboBox>

          <ComboBox Grid.Column="1" Width="110" FontSize="12"
                    ItemsSource="{Binding VersionFilters}"
                    SelectedItem="{Binding VersionFilter}" />

          <ComboBox Grid.Column="2" Width="110" FontSize="12"
                    ItemsSource="{Binding AvailableSortOptions}"
                    SelectedIndex="{Binding SortFieldIndex}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" FontSize="12"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>

          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8">
            <ComboBox Width="120" FontSize="12"
                      ItemsSource="{Binding InstalledVersions}"
                      SelectedItem="{Binding SelectedVersionId}"
                      IsEnabled="{Binding HasInstalledVersions}"
                      PlaceholderText="目标版本" />
            <TextBlock Text="{Binding VersionHintText}" FontSize="11" Foreground="{DynamicResource DangerBrush}"
                       IsVisible="{Binding !HasInstalledVersions}" VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>

      </StackPanel>
    </Border>

    <Border Grid.Row="2" CornerRadius="10" Background="{DynamicResource SurfaceBrush}"
            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
      <Grid>
        <ContentControl Content="{Binding DetailViewModel}" IsVisible="{Binding DetailViewModel, Converter={x:Static converters:NotNullConverter.Instance}}" />

        <ItemsControl IsVisible="{Binding IsLoading}" Margin="16">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="6" Padding="10" Margin="0,0,0,6"
                      Background="{DynamicResource SurfaceElevatedBrush}"
                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Opacity="0.5">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                  <Border Width="40" Height="40" CornerRadius="6" Background="{DynamicResource SurfaceHoverBrush}" Margin="0,0,10,0"/>
                  <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                    <Border Height="12" Width="160" Background="{DynamicResource SurfaceHoverBrush}" CornerRadius="3" />
                    <Border Height="10" Width="280" Background="{DynamicResource SurfaceHoverBrush}" CornerRadius="3" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ScrollViewer IsVisible="{Binding DetailViewModel, Converter={x:Static ObjectConverters.IsNull}}">
          <ItemsControl ItemsSource="{Binding Results}" Margin="12">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border CornerRadius="8" Padding="10" Margin="0,0,0,6"
                        Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                  <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

                    <Border Grid.RowSpan="2" Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource SurfaceHoverBrush}" VerticalAlignment="Center">
                      <Image Source="{Binding Icon}" Width="40" Height="40" />
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" Margin="10,0,0,2" />

                    <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="10,0,0,0">
                      <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" FontSize="11" MaxWidth="300"/>
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{Binding Author}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M5 20H19V18H5M19 9H15V3H9V9H5L12 16L19 9Z" Width="10" Height="10" Stretch="Uniform" Fill="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Downloads}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" />
                      </StackPanel>
                      <TextBlock Text="{Binding VersionDisplay, StringFormat=v{0}}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0,0,0">
                      <Button Content="详情" Classes="ghost" FontSize="12" Padding="10,4"
                              Command="{Binding #Root.((vm:ResourcesViewModel)DataContext).OpenDetailCommand}"
                              CommandParameter="{Binding}" />
                      <Button Content="下载" Classes="accent" FontSize="12" Padding="10,4"
                              Command="{Binding #Root.((vm:ResourcesViewModel)DataContext).DownloadCommand}"
                              CommandParameter="{Binding}" />
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</UserControl>
