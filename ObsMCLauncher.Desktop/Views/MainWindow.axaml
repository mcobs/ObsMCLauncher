<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ObsMCLauncher.Desktop.ViewModels"
        xmlns:converters="using:ObsMCLauncher.Desktop.Converters"
        xmlns:notif="using:ObsMCLauncher.Desktop.ViewModels.Notifications"
        xmlns:dialogs="using:ObsMCLauncher.Desktop.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="ObsMCLauncher.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app_icon.ico"
        Title="ObsMCLauncher"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="ListBox#NavListBox ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="ListBox#NavListBox ListBoxItem:selected Border.nav-item">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style Selector="ListBox#NavListBox ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="ListBox#NavListBox ListBoxItem:pointerover Border.nav-item">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>

        <Style Selector="ListBox#BottomNavListBox ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="ListBox#BottomNavListBox ListBoxItem:selected Border.nav-item">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style Selector="ListBox#BottomNavListBox ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="ListBox#BottomNavListBox ListBoxItem:pointerover Border.nav-item">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>

        <Style Selector="Border.nav-item">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.notification-card">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Width" Value="340" />
            <Setter Property="BoxShadow" Value="0 8 24 0 #40000000" />
            <Setter Property="Margin" Value="0,0,16,12" />
        </Style>

        <Style Selector="Border.dialog-card">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Width" Value="520" />
            <Setter Property="RenderTransform" Value="scale(0.9)" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CircularEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CircularEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.dialog-card:visible">
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border.authurl-card">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Width" Value="520" />
            <Setter Property="RenderTransform" Value="scale(0.9)" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CircularEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CircularEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.authurl-card:visible">
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border.update-dialog">
            <Setter Property="RenderTransform" Value="scale(0.9)" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CircularEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CircularEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.update-dialog:visible">
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border.download-panel">
            <Setter Property="RenderTransform" Value="translate(0, 20px)" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CircularEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CircularEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.download-panel:visible">
            <Setter Property="RenderTransform" Value="translate(0, 0)" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.titlebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.titlebar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>

        <Style Selector="Button.titlebar-close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123" />
        </Style>

        <Style Selector="Button.titlebar-close:pointerover TextBlock">
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid x:Name="RootGrid" RowDefinitions="40,*">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding NavWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Classes="chrome-surface"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="40">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" />
                    <TextBlock Text="黑曜石MC启动器" FontSize="13" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
                </StackPanel>

                <Panel Grid.Column="1" Background="Transparent">
                    <Border Height="40" Background="Transparent" PointerPressed="TitleBar_PointerPressed" />
                </Panel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Classes="titlebar-btn" Click="MinimizeButton_Click">
                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Line StartPoint="0,10" EndPoint="14,10" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                        </Viewbox>
                    </Button>
                    <Button Classes="titlebar-btn" Click="MaximizeButton_Click">
                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle Width="12" Height="12" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5" Fill="Transparent" Margin="1"/>
                        </Viewbox>
                    </Button>
                    <Button Classes="titlebar-btn titlebar-close" Click="CloseButton_Click">
                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="14" Height="14">
                                <Line StartPoint="1,1" EndPoint="13,13" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                                <Line StartPoint="13,1" EndPoint="1,13" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <Border x:Name="NavBorder" Grid.Row="1" Grid.Column="0"
                Classes="chrome-surface"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto,Auto">

                <Border Grid.Row="0" Padding="8,10" HorizontalAlignment="Left">
                    <Button Width="36"
                            Height="36"
                            Command="{Binding ToggleNavCommand}"
                            ToolTip.Tip="折叠/展开"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            RenderTransformOrigin="50%,50%">
                        <Button.RenderTransform>
                            <RotateTransform Angle="{Binding NavRotationAngle}" />
                        </Button.RenderTransform>
                        <Path Data="M3 6L21 6M3 12L21 12M3 18L21 18" Width="18" Height="14"
                              Stretch="Uniform" Stroke="{DynamicResource TextBrush}" StrokeThickness="2"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Border>

                <ListBox x:Name="NavListBox"
                         Grid.Row="1"
                         Margin="6,0"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         HorizontalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="nav-item"
                                    CornerRadius="8"
                                    Height="40"
                                    Padding="8,0"
                                    ToolTip.Tip="{Binding Title}">
                                <Grid ColumnDefinitions="24,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Icon}"
                                               FontSize="18"
                                               Width="24"
                                               Height="24"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="{Binding $parent[Window].DataContext.NavTextOpacity}"
                                               IsVisible="{Binding $parent[Window].DataContext.IsNavCollapsed, Converter={x:Static converters:NotConverter.Instance}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListBox x:Name="BottomNavListBox"
                         Grid.Row="2"
                         Margin="6,0"
                         ItemsSource="{Binding BottomNavItems}"
                         SelectedItem="{Binding SelectedBottomNavItem}"
                         HorizontalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="nav-item"
                                    CornerRadius="8"
                                    Height="40"
                                    Padding="8,0"
                                    ToolTip.Tip="{Binding Title}">
                                <Grid ColumnDefinitions="24,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Icon}"
                                               FontSize="18"
                                               Width="24"
                                               Height="24"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="{Binding $parent[Window].DataContext.NavTextOpacity}"
                                               IsVisible="{Binding $parent[Window].DataContext.IsNavCollapsed, Converter={x:Static converters:NotConverter.Instance}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3" Margin="6,12" IsVisible="{Binding !IsNavCollapsed}">
                    <TextBlock Text="{Binding NavCopyrightText}" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SystemControlBackgroundBaseHighBrush}">
            <TransitioningContentControl Content="{Binding CurrentPage}" Margin="20">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.2" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Border>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                Background="#80000000"
                IsVisible="{Binding Dialogs.IsAnyModalOpen}"
                IsHitTestVisible="{Binding Dialogs.IsAnyModalOpen}">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CircularEaseOut" />
                </Transitions>
            </Border.Transitions>
        </Border>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding Dialogs.IsOpen}"
                ZIndex="100"
                Classes="fluent-dialog"
                Opacity="{Binding Dialogs.Current.AnimationOpacity, FallbackValue=0}"
                RenderTransformOrigin="0.5,0.5"
                x:CompileBindings="False">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding Dialogs.Current.AnimationScale, FallbackValue=0.9}" ScaleY="{Binding Dialogs.Current.AnimationScale, FallbackValue=0.9}" />
                    <TranslateTransform Y="{Binding Dialogs.Current.AnimationOffsetY, FallbackValue=20}" />
                </TransformGroup>
            </Border.RenderTransform>
            
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        Classes="dialog-icon-container"
                        Margin="0,0,16,0"
                        IsVisible="True">
                    <PathIcon Data="{DynamicResource DialogInfoIcon}"
                              Classes="dialog-icon"
                              x:Name="DialogTypeIcon"/>
                </Border>
                
                <TextBlock Grid.Row="0" Grid.Column="1" 
                           Text="{Binding Dialogs.Current.Title, FallbackValue=''}" 
                           Classes="dialog-title"/>
                <Button Grid.Row="0" Grid.Column="2"
                        Width="32" Height="32"
                        Classes="ghost"
                        Command="{Binding Dialogs.CloseCommand}"
                        HorizontalAlignment="Right">
                    <Path Data="M6 6L18 18M6 18L18 6" 
                          Width="12" Height="12"
                          Stretch="Uniform"
                          Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                </Button>

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding Dialogs.Current.Message, FallbackValue=''}"
                           Classes="dialog-message"/>

                <TextBox Grid.Row="2" Grid.Column="1"
                         Margin="0,12,0,0"
                         Text="{Binding Dialogs.Current.InputText, Mode=TwoWay, FallbackValue=''}"
                         Watermark="{Binding Dialogs.Current.Placeholder, FallbackValue=''}"
                         IsVisible="{Binding Dialogs.Current.Type, Converter={x:Static converters:DialogInputVisibleConverter.Instance}, FallbackValue=False, TargetNullValue=False}" />

                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0" Spacing="8">
                    <Button Content="取消"
                            IsVisible="{Binding Dialogs.Current.Buttons, Converter={x:Static converters:DialogShowCancelConverter.Instance}, FallbackValue=False, TargetNullValue=False}"
                            Command="{Binding Dialogs.ChooseCommand}">
                        <Button.CommandParameter>
                            <dialogs:DialogResult>Cancel</dialogs:DialogResult>
                        </Button.CommandParameter>
                    </Button>
                    <Button Content="否"
                            IsVisible="{Binding Dialogs.Current.Buttons, Converter={x:Static converters:DialogShowNoConverter.Instance}, FallbackValue=False, TargetNullValue=False}"
                            Command="{Binding Dialogs.ChooseCommand}">
                        <Button.CommandParameter>
                            <dialogs:DialogResult>No</dialogs:DialogResult>
                        </Button.CommandParameter>
                    </Button>
                    <Button Content="是"
                            IsVisible="{Binding Dialogs.Current.Buttons, Converter={x:Static converters:DialogShowYesConverter.Instance}, FallbackValue=False, TargetNullValue=False}"
                            Command="{Binding Dialogs.ChooseCommand}">
                        <Button.CommandParameter>
                            <dialogs:DialogResult>Yes</dialogs:DialogResult>
                        </Button.CommandParameter>
                    </Button>
                    <Button Content="确定"
                            Classes="accent"
                            IsVisible="{Binding Dialogs.Current.Buttons, Converter={x:Static converters:DialogShowOkConverter.Instance}, FallbackValue=False, TargetNullValue=False}"
                            Command="{Binding Dialogs.ChooseCommand}">
                        <Button.CommandParameter>
                            <dialogs:DialogResult>OK</dialogs:DialogResult>
                        </Button.CommandParameter>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="AuthUrlOverlay"
                Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                Background="#80000000"
                IsVisible="{Binding Dialogs.IsAuthUrlOpen}"
                IsHitTestVisible="{Binding Dialogs.IsAuthUrlOpen}"
                PointerPressed="AuthUrlOverlay_PointerPressed"/>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding Dialogs.IsAuthUrlOpen}"
                IsHitTestVisible="True"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource SurfaceElevatedBrush}"
                Padding="24"
                Width="480"
                BoxShadow="0 8 32 0 #66000000"
                x:CompileBindings="False">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Border Width="40" Height="40" CornerRadius="8" Background="#1010B981" VerticalAlignment="Center">
                            <Path Data="M12 1L3 5V11C3 16.5 6.8 21.7 12 23C17.2 21.7 21 16.5 21 11V5L12 1M12 11H19C18.5 15.5 15.7 19.6 12 20.9V11H5V6.3L12 3.2V11Z"
                                  Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Dialogs.AuthUrlCurrent.Title, FallbackValue='微软账户登录'}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            Classes="ghost"
                            Command="{Binding Dialogs.CloseAuthUrlCommand}"
                            CommandParameter="{x:True}">
                        <Path Data="M6 6L18 18M6 18L18 6" 
                              Width="12" Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                    </Button>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="浏览器应已自动打开，如果没有，请手动复制下方链接并在浏览器中打开："
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="授权链接" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <SelectableTextBlock Text="{Binding Dialogs.AuthUrlCurrent.Url, FallbackValue=''}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button Grid.Row="3"
                        Classes="accent"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        Command="{Binding Dialogs.CopyAuthUrlCommand}"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Path Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5M19 21H8V7H19V21Z"
                              Width="14" Height="14" Stretch="Uniform" Fill="White" VerticalAlignment="Center"/>
                        <TextBlock Text="复制授权链接" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Row="4"
                           Text="完成授权后此对话框将自动关闭，也可点击右上角关闭按钮手动关闭"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding Dialogs.IsUpdateDialogOpen}"
                IsHitTestVisible="{Binding Dialogs.IsUpdateDialogOpen}"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                MaxWidth="600"
                MaxHeight="700"
                Padding="24"
                Opacity="{Binding Dialogs.UpdateDialogCurrent.AnimationOpacity, FallbackValue=0}"
                RenderTransformOrigin="0.5,0.5"
                x:CompileBindings="False"
                Classes="update-dialog">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding Dialogs.UpdateDialogCurrent.AnimationScale, FallbackValue=0.5}" ScaleY="{Binding Dialogs.UpdateDialogCurrent.AnimationScale, FallbackValue=0.5}" />
                    <TranslateTransform Y="{Binding Dialogs.UpdateDialogCurrent.AnimationOffsetY, FallbackValue=-40}" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="{Binding Dialogs.UpdateDialogCurrent.Title, FallbackValue=''}" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />

                <ScrollViewer Grid.Row="1" MaxHeight="400" Margin="0,0,0,25">
                    <TextBlock Text="{Binding Dialogs.UpdateDialogCurrent.MarkdownContent, FallbackValue=''}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="22" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button Content="{Binding Dialogs.UpdateDialogCurrent.CancelText, FallbackValue='取消'}"
                            Width="100"
                            Command="{Binding Dialogs.CloseUpdateDialogCommand}"
                            CommandParameter="{x:False}" />
                    <Button Content="{Binding Dialogs.UpdateDialogCurrent.ConfirmText, FallbackValue='确定'}"
                            Width="120"
                            Classes="accent"
                            Command="{Binding Dialogs.CloseUpdateDialogCommand}"
                            CommandParameter="{x:True}" />
                </StackPanel>
            </Grid>
        </Border>

        <Button Grid.Row="1"
                Grid.Column="1"
                Width="52"
                Height="52"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,28,28"
                CornerRadius="26"
                Foreground="White"
                IsVisible="{Binding DownloadManager.HasActiveTasks}"
                Command="{Binding DownloadManager.TogglePanelVisibilityCommand}">
            <Button.Background>
                <SolidColorBrush Color="{DynamicResource SystemAccentColor}" />
            </Button.Background>
            <Grid>
                <Path Data="M12 4V1L8 5L12 9V6C15.31 6 18 8.69 18 12C18 13.01 17.75 13.97 17.3 14.8L18.76 16.26C19.54 14.99 20 13.55 20 12C20 7.58 16.42 4 12 4M12 18C8.69 18 6 15.31 6 12C6 10.99 6.25 10.03 6.7 9.2L5.24 7.74C4.46 9.01 4 10.45 4 12C4 16.42 7.58 20 12 20V23L16 19L12 15V18Z"
                      Width="20" Height="20"
                      Stretch="Uniform"
                      Fill="White"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border Width="20"
                        Height="20"
                        CornerRadius="10"
                        Background="{DynamicResource DangerBrush}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-6,-6,0"
                        IsVisible="{Binding DownloadManager.ActiveTaskCount, Converter={x:Static converters:GreaterThanZeroToIsVisibleConverter.Instance}}">
                    <TextBlock Text="{Binding DownloadManager.ActiveTaskCount}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Button>

        <Border Grid.Row="1"
                Grid.Column="1"
                Width="400"
                MaxHeight="500"
                CornerRadius="14"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,96,28"
                IsVisible="{Binding DownloadManager.IsPanelVisible}"
                BoxShadow="0 8 32 0 #66000000"
                Classes="download-panel">

            <Grid RowDefinitions="Auto,*,Auto">
                <Border CornerRadius="14,14,0,0"
                        Padding="16,12">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource SystemAccentColor}" />
                    </Border.Background>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="M12 4V1L8 5L12 9V6C15.31 6 18 8.69 18 12C18 13.01 17.75 13.97 17.3 14.8L18.76 16.26C19.54 14.99 20 13.55 20 12C20 7.58 16.42 4 12 4M12 18C8.69 18 6 15.31 6 12C6 10.99 6.25 10.03 6.7 9.2L5.24 7.74C4.46 9.01 4 10.45 4 12C4 16.42 7.58 20 12 20V23L16 19L12 15V18Z"
                                  Width="16" Height="16"
                                  Stretch="Uniform" Fill="White"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="下载管理器" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Foreground="White" Opacity="0.85" VerticalAlignment="Center">
                                <Run Text="("/><Run Text="{Binding DownloadManager.ActiveTaskCount}"/><Run Text=" 个任务)"/>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="28"
                                Height="28"
                                Classes="ghost"
                                Foreground="White"
                                Command="{Binding DownloadManager.ClosePanelCommand}">
                            <Path Data="M6 6L18 18M6 18L18 6" 
                                  Width="10" Height="10"
                                  Stretch="Uniform"
                                  Stroke="White" StrokeThickness="2"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding DownloadManager.Tasks}" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" Margin="0,0,0,8"
                                        Background="{DynamicResource SystemControlBackgroundBaseHighBrush}">
                                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />

                                        <Button Grid.Row="0" Grid.Column="1" Width="24" Height="24"
                                                Classes="ghost" Padding="0"
                                                IsVisible="{Binding CanCancel}"
                                                Command="{Binding $parent[Window].DataContext.DownloadManager.CancelTaskCommand}"
                                                CommandParameter="{Binding Id}">
                                            <Path Data="M6 6L18 18M6 18L18 6" 
                                                  Width="10" Height="10"
                                                  Stretch="Uniform"
                                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                                        </Button>

                                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="4" Minimum="0" Maximum="100" Value="{Binding Progress}" Margin="0,8,0,6" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />

                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding ProgressText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Text="{Binding SpeedText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="0,0,14,14"
                        Padding="12">
                    <Button Content="清除已完成"
                            Classes="ghost"
                            HorizontalAlignment="Right"
                            Command="{Binding DownloadManager.ClearInactiveTasksCommand}" />
                </Border>
            </Grid>
        </Border>

        <ItemsControl x:Name="NotificationItemsControl"
                      Grid.Row="0"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Grid.RowSpan="2"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,12,0,0"
                      IsHitTestVisible="True"
                      ItemsSource="{Binding Notifications.Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="10" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="notif:NotificationItemViewModel">
                    <Border Classes="notification-card" 
                            IsHitTestVisible="True"
                            Opacity="{Binding AnimationOpacity}"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding AnimationScale}" ScaleY="{Binding AnimationScale}" />
                                <TranslateTransform Y="{Binding AnimationOffsetY}" />
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                            <Button Grid.Row="0" Grid.Column="1"
                                    Width="24" Height="24"
                                    Classes="ghost" Padding="0"
                                    IsVisible="{Binding CanClose}"
                                    Command="{Binding CloseCommand}">
                                <Path Data="M6 6L18 18M6 18L18 6" 
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                            </Button>

                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Message}" Opacity="0.8" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>

                            <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                         Height="3"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding Progress}"
                                         IsIndeterminate="False"
                                         IsVisible="{Binding IsProgress}"
                                         Margin="0,8,0,0" />

                            <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                         Height="3"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding CountdownProgress}"
                                         IsIndeterminate="False"
                                         IsVisible="{Binding IsCountdown}"
                                         Margin="0,8,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>

</Window>
