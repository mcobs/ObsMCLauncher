<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ObsMCLauncher.Desktop.ViewModels"
             xmlns:converters="using:ObsMCLauncher.Desktop.Converters"
             x:Class="ObsMCLauncher.Desktop.Views.InstanceView"
             x:DataType="vm:InstanceViewModel">

  <Panel IsVisible="{Binding IsVisible}"
         ZIndex="10"
         HorizontalAlignment="Stretch"
         VerticalAlignment="Stretch">
    <Border Background="{DynamicResource BackgroundBrush}">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
      <!-- 顶部标题栏 -->
      <Border Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              Padding="16,10"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource BorderBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Command="{Binding CloseCommand}" Classes="ghost">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M20 11H7.83L13.42 5.41L12 4L4 12L12 20L13.41 18.59L7.83 13H20V11Z" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="返回" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <TextBlock Grid.Column="1"
                     Text="{Binding VersionId}"
                     FontSize="16"
                     FontWeight="Medium"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- 导航栏：底色与内容区保持一致，通过底部边框区分 -->
      <Border Grid.Row="1"
              Background="{DynamicResource BackgroundBrush}"
              Padding="16,0"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource BorderBrush}">
        <StackPanel Orientation="Horizontal" Spacing="0">
          <Button Classes="nav-tab"
                  Foreground="{Binding IsBasicTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsBasicTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="基本信息" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="nav-tab"
                  Foreground="{Binding IsSettingsTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsSettingsTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="1">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="版本设置" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="nav-tab"
                  Foreground="{Binding IsWorldsTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsWorldsTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="2">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2M12 20C7.59 20 4 16.41 4 12S7.59 4 12 4 20 7.59 20 12 16.41 20 12 20M11 7H13V13H11V7M11 15H13V17H11V15Z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="存档" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="nav-tab"
                  Foreground="{Binding IsModsTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsModsTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="3">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="Mod" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="nav-tab"
                  Foreground="{Binding IsShaderTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsShaderTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M21 3H3C1.9 3 1 3.9 1 5V19C1 20.1 1.9 21 3 21H21C22.1 21 23 20.1 23 19V5C23 3.9 22.1 3 21 3M21 19H3V5H21V19M7.5 13.5L10 16.5L14 11.5L19 17H5L7.5 13.5Z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="Shader" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Classes="nav-tab"
                  Foreground="{Binding IsResourcePacksTab, Converter={x:Static converters:BoolToBrushConverter.NavTab}}"
                  FontWeight="{Binding IsResourcePacksTab, Converter={x:Static converters:BoolToFontWeightConverter.NavTab}}"
                  Command="{Binding SelectNavCommand}" CommandParameter="5">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                    Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="材质包" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="12" MaxWidth="900" HorizontalAlignment="Stretch">

          <!-- ===== 基本信息 Tab ===== -->
          <StackPanel IsVisible="{Binding IsBasicTab}" Spacing="12">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16,12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <Grid ColumnDefinitions="*,*,*">
                <StackPanel>
                  <TextBlock Text="实际版本" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3"/>
                  <TextBlock Text="{Binding ActualVersion}" FontSize="13" FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                  <TextBlock Text="版本类型" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding VersionType}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                  <TextBlock Text="上次游玩" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3" HorizontalAlignment="Right"/>
                  <TextBlock Text="{Binding LastPlayed}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- 版本描述 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="版本描述" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Classes="ghost" FontSize="11" Padding="8,4"
                          Command="{Binding StartEditDescriptionCommand}"
                          IsVisible="{Binding !IsEditingDescription}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                            Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                      <TextBlock Text="编辑" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>

                <!-- 显示模式 -->
                <TextBlock Text="{Binding Description}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           IsVisible="{Binding !IsEditingDescription}"/>

                <!-- 编辑模式 -->
                <StackPanel IsVisible="{Binding IsEditingDescription}" Spacing="8">
                  <TextBox Text="{Binding EditingDescription}"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Watermark="输入版本描述..."
                           MinHeight="80"
                           MaxWidth="600"/>
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="取消" Classes="ghost" Command="{Binding CancelEditDescriptionCommand}"/>
                    <Button Content="保存" Command="{Binding SaveDescriptionCommand}"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- 存储路径 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="8">
                <TextBlock Text="存储路径" FontSize="14" FontWeight="Medium"/>
                <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="6" Padding="10,8"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding StoragePath}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <Button Grid.Column="1" Classes="ghost" Padding="6,4" VerticalAlignment="Center"
                            Command="{Binding OpenFolderCommand}" ToolTip.Tip="打开文件夹">
                      <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                            Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                    </Button>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <!-- 快捷操作 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="12,10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                <Button Classes="ghost" Padding="10,6" Command="{Binding OpenModsFolderCommand}" ToolTip.Tip="打开Mod文件夹">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                          Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Mod" FontSize="12" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button Classes="ghost" Padding="10,6" Command="{Binding OpenShaderPacksFolderCommand}" ToolTip.Tip="打开Shader文件夹">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Path Data="M21 3H3C1.9 3 1 3.9 1 5V19C1 20.1 1.9 21 3 21H21C22.1 21 23 20.1 23 19V5C23 3.9 22.1 3 21 3M21 19H3V5H21V19M7.5 13.5L10 16.5L14 11.5L19 17H5L7.5 13.5Z"
                          Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Shader" FontSize="12" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button Classes="ghost" Padding="10,6" Command="{Binding OpenResourcePacksFolderCommand}" ToolTip.Tip="打开资源包文件夹">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Path Data="M11 21h2v-3h-2v3zM5 21h2v-3H5v3zM17 21h2v-3h-2v3zM5 17h2v-3H5v3zM17 17h2v-3h-2v3zM5 13h2v-3H5v3zM17 13h2v-3h-2v3zM11 17h2v-3h-2v3zM11 13h2v-3h-2v3zM11 9h2V6h2V4h-2V1h-2v3H9v2h2v3z"
                          Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="资源包" FontSize="12" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button Classes="ghost" Padding="10,6" Command="{Binding OpenConfigFolderCommand}" ToolTip.Tip="打开配置文件夹">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                          Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="配置" FontSize="12" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>

            <!-- ===== 高级管理 ===== -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <TextBlock Text="高级管理" FontSize="14" FontWeight="Medium"/>
                <TextBlock Text="版本运维工具，请谨慎操作" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4" Margin="0,4,0,0">
                  <Button Classes="ghost" Padding="8,10" Command="{Binding ExportLaunchScriptCommand}">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                      <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                            Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                      <TextBlock Text="导出启动脚本" FontSize="12"/>
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="1" Classes="ghost" Padding="8,10" Command="{Binding CompleteFilesCommand}">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                      <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"
                            Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                      <TextBlock Text="补全文件" FontSize="12"/>
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="2" Classes="danger" Padding="8,10" Command="{Binding DeleteVersionCommand}">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                      <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                            Width="18" Height="18" Stretch="Uniform" Fill="Red"/>
                      <TextBlock Text="删除版本" FontSize="12" Foreground="Red"/>
                    </StackPanel>
                  </Button>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ===== 版本设置 Tab ===== -->
          <StackPanel IsVisible="{Binding IsSettingsTab}" Spacing="12">
            <!-- 版本隔离与分组 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <TextBlock Text="版本隔离与分组" FontSize="14" FontWeight="Medium"/>

                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock Text="版本隔离" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="开启后此版本使用独立的游戏目录" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                  </StackPanel>
                  <ComboBox Grid.Column="1" Width="140" SelectedIndex="{Binding IsolationMode}" FontSize="12">
                    <ComboBoxItem Content="跟随全局"/>
                    <ComboBoxItem Content="开启"/>
                    <ComboBoxItem Content="关闭"/>
                  </ComboBox>
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock Text="版本分组" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="将此版本分配到指定分组" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                  </StackPanel>
                  <ComboBox Grid.Column="1" Width="160"
                            ItemsSource="{Binding GroupListItems}"
                            SelectedItem="{Binding SelectedGroupItem}"
                            FontSize="12">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <Panel>
                          <TextBlock Text="{Binding Name}" FontSize="12"
                                     IsVisible="{Binding IsNormalItem}"/>
                          <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsManageEntry}">
                            <Path Data="M19.14 12.94C19.18 12.64 19.2 12.33 19.2 12C19.2 11.68 19.18 11.36 19.13 11.06L21.16 9.48C21.34 9.34 21.39 9.07 21.28 8.87L19.36 5.55C19.24 5.33 18.99 5.26 18.77 5.33L16.38 6.29C15.88 5.91 15.35 5.59 14.76 5.35L14.4 2.81C14.36 2.57 14.16 2.4 13.92 2.4H10.08C9.84 2.4 9.65 2.57 9.61 2.81L9.25 5.35C8.66 5.59 8.12 5.92 7.63 6.29L5.24 5.33C5.02 5.25 4.77 5.33 4.65 5.55L2.74 8.87C2.62 9.08 2.66 9.34 2.86 9.48L4.89 11.06C4.84 11.36 4.8 11.69 4.8 12C4.8 12.31 4.82 12.64 4.87 12.94L2.85 14.52C2.67 14.66 2.62 14.93 2.73 15.13L4.65 18.45C4.77 18.67 5.02 18.74 5.24 18.67L7.63 17.71C8.13 18.09 8.66 18.41 9.25 18.65L9.61 21.19C9.65 21.43 9.84 21.6 10.08 21.6H13.92C14.16 21.6 14.36 21.43 14.4 21.19L14.76 18.65C15.35 18.41 15.89 18.09 16.38 17.71L18.77 18.67C18.99 18.74 19.24 18.67 19.36 18.45L21.28 15.13C21.39 14.91 21.34 14.66 21.16 14.52L19.14 12.94ZM12 15.6C10.02 15.6 8.4 13.98 8.4 12C8.4 10.02 10.02 8.4 12 8.4C13.98 8.4 15.6 10.02 15.6 12C15.6 13.98 13.98 15.6 12 15.6Z"
                                  Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="管理分组..." FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Panel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>
            </Border>

            <!-- 内存配置 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock Text="内存配置" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="{Binding GlobalMemoryText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseCustomMemory}" OnContent="自定义" OffContent="跟随全局"/>
                </Grid>

                <StackPanel Spacing="10" IsVisible="{Binding UseCustomMemory}">
                  <Border Height="1" Background="{DynamicResource DividerBrush}"/>

                  <!-- 最大内存 -->
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="最大内存" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CustomMaxMemory}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="MB" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,80">
                      <Slider Grid.Column="0" Minimum="512" Maximum="16384" Value="{Binding CustomMaxMemory}"/>
                      <TextBox Grid.Column="1" Text="{Binding CustomMaxMemory}" HorizontalContentAlignment="Right" Watermark="MB"/>
                    </Grid>
                  </StackPanel>

                  <!-- 最小内存 -->
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="最小内存" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CustomMinMemory}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="MB" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,80">
                      <Slider Grid.Column="0" Minimum="256" Maximum="8192" Value="{Binding CustomMinMemory}"/>
                      <TextBox Grid.Column="1" Text="{Binding CustomMinMemory}" HorizontalContentAlignment="Right" Watermark="MB"/>
                    </Grid>
                  </StackPanel>

                  <TextBlock Text="建议: 最小内存不超过最大内存的1/4，最大内存不超过系统可用内存的70%"
                             FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ===== 存档 Tab ===== -->
          <StackPanel IsVisible="{Binding IsWorldsTab}" Spacing="12">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="存档管理" FontSize="14" FontWeight="Medium"/>
                  <Button Grid.Column="1" Classes="ghost" FontSize="11" Padding="4,2"
                          Command="{Binding OpenSavesFolderCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                      <TextBlock Text="打开存档文件夹" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </Grid>

                <ItemsControl ItemsSource="{Binding Worlds}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,6"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <!-- 存档图标，无图标时回退到默认地球图形 -->
                          <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,10,0"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ClipToBounds="True">
                            <Panel>
                              <Path Data="M12 2C6.48 2 2 6.48 2 12S6.48 22 12 22 22 17.52 22 12 17.52 2 12 2M12 20C7.59 20 4 16.41 4 12S7.59 4 12 4 20 7.59 20 12 16.41 20 12 20M11 7H13V13H11V7M11 15H13V17H11V15Z"
                                    Width="24" Height="24" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                              <Image Source="{Binding IconPath, Converter={x:Static converters:FilePathToBitmapConverter.Instance}}"
                                     Stretch="UniformToFill"
                                     Margin="2"/>
                            </Panel>
                          </Border>

                          <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding GameVersion, StringFormat='版本: {0}'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                              <TextBlock Text="{Binding WorldSizeDisplay, StringFormat='大小: {0}'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding CreationTime, StringFormat='创建: {0:yyyy-MM-dd HH:mm}'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                              <TextBlock Text="{Binding LastModified, StringFormat='修改: {0:yyyy-MM-dd HH:mm}'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </StackPanel>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="暂无存档"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding !HasWorlds}"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ===== Mod Tab ===== -->
          <StackPanel IsVisible="{Binding IsModsTab}" Spacing="12">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Mod 管理" FontSize="14" FontWeight="Medium"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding RefreshModsCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding OpenModsFolderCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="打开Mod文件夹" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding Mods}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,6"
                              BorderThickness="1"
                              BorderBrush="{Binding HasConflict, Converter={x:Static converters:BoolToBrushConverter.ConflictBorder}}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <!-- Mod 图标 -->
                          <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,10,0"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ClipToBounds="True">
                            <Image Source="{Binding IconPath, Converter={x:Static converters:FilePathToBitmapConverter.Instance}}"
                                   Stretch="Uniform"
                                   Margin="3"/>
                          </Border>

                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                              <Border Background="#30FF5252" CornerRadius="3" Padding="4,1" IsVisible="{Binding HasConflict}">
                                <TextBlock Text="冲突" FontSize="9" Foreground="#FF5252" FontWeight="Medium"/>
                              </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                              <TextBlock Text="{Binding ModId}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" IsVisible="{Binding ModId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                              <TextBlock Text="{Binding Version}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" IsVisible="{Binding Version, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                              <TextBlock Text="{Binding Loader}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" IsVisible="{Binding Loader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ConflictDescription}" FontSize="10" Foreground="#FF5252" TextWrapping="Wrap" IsVisible="{Binding HasConflict}" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding ConflictSuggestion}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap" IsVisible="{Binding ConflictSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Margin="0,2,0,0"/>
                          </StackPanel>

                          <ToggleSwitch Grid.Column="2"
                                        IsChecked="{Binding IsEnabled}"
                                        OnContent="" OffContent=""/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="暂无Mod"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding !HasMods}"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ===== Shader Tab ===== -->
          <StackPanel IsVisible="{Binding IsShaderTab}" Spacing="12">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Shader Pack 管理" FontSize="14" FontWeight="Medium"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding RefreshShaderPacksCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding OpenShaderPacksFolderCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="打开文件夹" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding ShaderPacks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,6"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                          <!-- 光影包图标，无图标时回退到默认图形 -->
                          <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,10,0"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ClipToBounds="True">
                            <Panel>
                              <Path Data="M21 3H3C1.9 3 1 3.9 1 5V19C1 20.1 1.9 21 3 21H21C22.1 21 23 20.1 23 19V5C23 3.9 22.1 3 21 3M21 19H3V5H21V19M7.5 13.5L10 16.5L14 11.5L19 17H5L7.5 13.5Z"
                                    Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                              <Image Source="{Binding IconPath, Converter={x:Static converters:FilePathToBitmapConverter.Instance}}"
                                     Stretch="Uniform"
                                     Margin="3"/>
                            </Panel>
                          </Border>

                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Size, StringFormat='{}{0:F0} KB'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                          </StackPanel>

                          <Button Grid.Column="2" Classes="ghost" Padding="4,2" Margin="4,0,0,0"
                                  Command="{Binding $parent[ItemsControl].((vm:InstanceViewModel)DataContext).DeleteShaderPackCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="删除">
                            <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                  Width="14" Height="14" Stretch="Uniform" Fill="#FF5252" VerticalAlignment="Center"/>
                          </Button>

                          <ToggleSwitch Grid.Column="3"
                                        IsChecked="{Binding IsEnabled}"
                                        OnContent="" OffContent=""
                                        Margin="8,0,0,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="暂无 Shader Pack"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding !HasShaderPacks}"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ===== 材质包 Tab ===== -->
          <StackPanel IsVisible="{Binding IsResourcePacksTab}" Spacing="12">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="材质包管理" FontSize="14" FontWeight="Medium"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding RefreshResourcePacksCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <Button Classes="ghost" FontSize="11" Padding="4,2"
                            Command="{Binding OpenResourcePacksFolderCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="3">
                        <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="打开文件夹" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding ResourcePacks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,6"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                          <!-- 材质包图标，无图标时回退到默认图形 -->
                          <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,10,0"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ClipToBounds="True">
                            <Panel>
                              <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                                    Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                              <Image Source="{Binding IconPath, Converter={x:Static converters:FilePathToBitmapConverter.Instance}}"
                                     Stretch="Uniform"
                                     Margin="3"/>
                            </Panel>
                          </Border>

                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Size, StringFormat='{}{0:F0} KB'}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                          </StackPanel>

                          <Button Grid.Column="2" Classes="ghost" Padding="4,2" Margin="4,0,0,0"
                                  Command="{Binding $parent[ItemsControl].((vm:InstanceViewModel)DataContext).DeleteResourcePackCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="删除">
                            <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                  Width="14" Height="14" Stretch="Uniform" Fill="#FF5252" VerticalAlignment="Center"/>
                          </Button>

                          <ToggleSwitch Grid.Column="3"
                                        IsChecked="{Binding IsEnabled}"
                                        OnContent="" OffContent=""
                                        Margin="8,0,0,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="暂无材质包"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding !HasResourcePacks}"/>
              </StackPanel>
            </Border>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="3"
              Background="#C0000000"
              IsVisible="{Binding IsLoading}"
              ZIndex="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
          <ProgressBar IsIndeterminate="True" Width="120"/>
          <TextBlock Text="加载中..." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>
    </Border>

    <!-- 分组管理弹窗 -->
    <Border IsVisible="{Binding IsGroupManagerOpen}"
            Background="#80000000"
            ZIndex="200"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <Border Background="{DynamicResource BackgroundBrush}"
              CornerRadius="12"
              Width="360"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              BorderThickness="1"
              BorderBrush="{DynamicResource BorderBrush}"
              BoxShadow="0 8 32 0 #40000000">
        <Grid RowDefinitions="Auto,*,Auto" Margin="0">

          <Border Grid.Row="0" Padding="16,14" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="分组管理" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Width="28" Height="28" Padding="0" Classes="ghost"
                      Command="{Binding CloseGroupManagerCommand}">
                <Path Data="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"
                      Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
            <StackPanel Margin="8,8,8,4">
              <ItemsControl ItemsSource="{Binding ManagedGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,4"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                IsVisible="{Binding IsSystem}"
                                VerticalAlignment="Center">
                          <TextBlock Text="系统组" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                    IsVisible="{Binding IsDeletable}">
                          <Button Width="26" Height="26" Padding="0" Classes="ghost" ToolTip.Tip="重命名"
                                  Command="{Binding $parent[UserControl].((vm:InstanceViewModel)DataContext).RenameGroupCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                  Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                          <Button Width="26" Height="26" Padding="0" Classes="ghost" ToolTip.Tip="删除"
                                  Command="{Binding $parent[UserControl].((vm:InstanceViewModel)DataContext).DeleteGroupCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="M19 4H15.5L14.5 3H9.5L8.5 4H5V6H19M6 19A2 2 0 0 0 8 21H16A2 2 0 0 0 18 19V7H6V19Z"
                                  Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource DangerBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <Border Grid.Row="2" Padding="12,10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Watermark="输入新分组名称" Text="{Binding NewGroupName}" FontSize="13"/>
              <Button Grid.Column="1" Content="创建" Margin="8,0,0,0" Padding="14,0"
                      Command="{Binding CreateGroupCommand}"/>
            </Grid>
          </Border>

        </Grid>
      </Border>
    </Border>

  </Panel>
</UserControl>
