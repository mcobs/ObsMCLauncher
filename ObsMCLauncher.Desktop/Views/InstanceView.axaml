<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ObsMCLauncher.Desktop.ViewModels"
             xmlns:converters="using:ObsMCLauncher.Desktop.Converters"
             x:Class="ObsMCLauncher.Desktop.Views.InstanceView"
             x:DataType="vm:InstanceViewModel">

  <Panel IsVisible="{Binding IsVisible}"
         ZIndex="10"
         HorizontalAlignment="Stretch"
         VerticalAlignment="Stretch">
    <Border Background="{DynamicResource BackgroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto">
      <Border Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              Padding="16,10"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource BorderBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Command="{Binding CloseCommand}" Classes="ghost">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Data="M20 11H7.83L13.42 5.41L12 4L4 12L12 20L13.41 18.59L7.83 13H20V11Z" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="返回" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <TextBlock Grid.Column="1"
                     Text="{Binding VersionId}"
                     FontSize="16"
                     FontWeight="Medium"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="12" MaxWidth="900" HorizontalAlignment="Stretch">
          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="10"
                  Padding="16,12"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderBrush}">
            <Grid ColumnDefinitions="*,*,*">
              <StackPanel>
                <TextBlock Text="实际版本" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding ActualVersion}" FontSize="13" FontWeight="Medium"/>
              </StackPanel>

              <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="版本类型" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding VersionType}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
              </StackPanel>

              <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock Text="上次游玩" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,3" HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding LastPlayed}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="10"
                  Padding="16"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Spacing="12">
              <TextBlock Text="版本设置" FontSize="14" FontWeight="Medium"/>

              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="版本隔离" FontSize="12" FontWeight="SemiBold"/>
                  <TextBlock Text="开启后此版本使用独立的游戏目录" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                </StackPanel>
                <ComboBox Grid.Column="1" Width="140" SelectedIndex="{Binding IsolationMode}" FontSize="12">
                  <ComboBoxItem Content="跟随全局"/>
                  <ComboBoxItem Content="开启"/>
                  <ComboBoxItem Content="关闭"/>
                </ComboBox>
              </Grid>

              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="版本分组" FontSize="12" FontWeight="SemiBold"/>
                  <TextBlock Text="将此版本分配到指定分组" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                </StackPanel>
                <ComboBox Grid.Column="1" Width="160"
                          ItemsSource="{Binding GroupListItems}"
                          SelectedItem="{Binding SelectedGroupItem}"
                          FontSize="12">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <Panel>
                        <!-- 普通分组项 -->
                        <TextBlock Text="{Binding Name}" FontSize="12"
                                   IsVisible="{Binding !IsSeparator}"/>
                        <!-- 管理入口项 -->
                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsManageEntry}">
                          <Path Data="M19.14 12.94C19.18 12.64 19.2 12.33 19.2 12C19.2 11.68 19.18 11.36 19.13 11.06L21.16 9.48C21.34 9.34 21.39 9.07 21.28 8.87L19.36 5.55C19.24 5.33 18.99 5.26 18.77 5.33L16.38 6.29C15.88 5.91 15.35 5.59 14.76 5.35L14.4 2.81C14.36 2.57 14.16 2.4 13.92 2.4H10.08C9.84 2.4 9.65 2.57 9.61 2.81L9.25 5.35C8.66 5.59 8.12 5.92 7.63 6.29L5.24 5.33C5.02 5.25 4.77 5.33 4.65 5.55L2.74 8.87C2.62 9.08 2.66 9.34 2.86 9.48L4.89 11.06C4.84 11.36 4.8 11.69 4.8 12C4.8 12.31 4.82 12.64 4.87 12.94L2.85 14.52C2.67 14.66 2.62 14.93 2.73 15.13L4.65 18.45C4.77 18.67 5.02 18.74 5.24 18.67L7.63 17.71C8.13 18.09 8.66 18.41 9.25 18.65L9.61 21.19C9.65 21.43 9.84 21.6 10.08 21.6H13.92C14.16 21.6 14.36 21.43 14.4 21.19L14.76 18.65C15.35 18.41 15.89 18.09 16.38 17.71L18.77 18.67C18.99 18.74 19.24 18.67 19.36 18.45L21.28 15.13C21.39 14.91 21.34 14.66 21.16 14.52L19.14 12.94ZM12 15.6C10.02 15.6 8.4 13.98 8.4 12C8.4 10.02 10.02 8.4 12 8.4C13.98 8.4 15.6 10.02 15.6 12C15.6 13.98 13.98 15.6 12 15.6Z"
                                Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Text="管理分组..." FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Panel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Separator/>

              <StackPanel Spacing="4">
                <TextBlock Text="存储路径" FontSize="12" FontWeight="Medium"/>
                <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="6" Padding="10,8"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding StoragePath}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <Button Grid.Column="1" Classes="ghost" Padding="6,4" VerticalAlignment="Center"
                            Command="{Binding OpenFolderCommand}" ToolTip.Tip="打开文件夹">
                      <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z"
                            Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                    </Button>
                  </Grid>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="10"
                  Padding="16"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Spacing="12">
              <TextBlock Text="存档管理" FontSize="14" FontWeight="Medium"/>

              <ItemsControl ItemsSource="{Binding Worlds}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,6"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12S6.48 22 12 22 22 17.52 22 12 17.52 2 12 2M12 20C7.59 20 4 16.41 4 12S7.59 4 12 4 20 7.59 20 12 16.41 20 12 20M11 7H13V13H11V7M11 15H13V17H11V15Z" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"/>
                          <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="ghost" FontSize="11" Padding="4,2"
                                Command="{Binding $parent[UserControl].DataContext.OpenSavesFolderCommand}">
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="打开" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="暂无存档"
                         FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding !HasWorlds}"/>
            </StackPanel>
          </Border>

          <Border Background="{DynamicResource SurfaceBrush}"
                  CornerRadius="10"
                  Padding="16"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Mod 管理" FontSize="14" FontWeight="Medium"/>
                <Button Grid.Column="1" Classes="ghost" FontSize="11" Padding="4,2"
                        Command="{Binding OpenModsFolderCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="3">
                    <Path Data="M20 6H12L10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6M20 18H4V8H20V18Z" Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="打开Mod文件夹" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </Grid>

              <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,6"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Width="7" Height="7" CornerRadius="3.5" Margin="0,0,8,0" VerticalAlignment="Center">
                          <Border.Background>
                            <SolidColorBrush Color="{Binding IsEnabled, Converter={x:Static converters:BoolToColorConverter.Instance}}"/>
                          </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="2"
                                      IsChecked="{Binding IsEnabled}"
                                      OnContent="" OffContent=""/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="暂无Mod"
                         FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding !HasMods}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="2"
              Background="#C0000000"
              IsVisible="{Binding IsLoading}"
              ZIndex="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
          <ProgressBar IsIndeterminate="True" Width="120"/>
          <TextBlock Text="加载中..." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>
    </Border>

    <!-- 分组管理弹窗 -->
    <Border IsVisible="{Binding IsGroupManagerOpen}"
            Background="#80000000"
            ZIndex="200"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <Border Background="{DynamicResource BackgroundBrush}"
              CornerRadius="12"
              Width="360"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              BorderThickness="1"
              BorderBrush="{DynamicResource BorderBrush}"
              BoxShadow="0 8 32 0 #40000000">
        <Grid RowDefinitions="Auto,*,Auto" Margin="0">

          <Border Grid.Row="0" Padding="16,14" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="分组管理" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Width="28" Height="28" Padding="0" Classes="ghost"
                      Command="{Binding CloseGroupManagerCommand}">
                <Path Data="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"
                      Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
            <StackPanel Margin="8,8,8,4">
              <ItemsControl ItemsSource="{Binding ManagedGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,4"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                IsVisible="{Binding IsSystem}"
                                VerticalAlignment="Center">
                          <TextBlock Text="系统组" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </Border>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                    IsVisible="{Binding IsDeletable}">
                          <Button Width="26" Height="26" Padding="0" Classes="ghost" ToolTip.Tip="重命名"
                                  Command="{Binding $parent[UserControl].((vm:InstanceViewModel)DataContext).RenameGroupCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                  Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource TextBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                          <Button Width="26" Height="26" Padding="0" Classes="ghost" ToolTip.Tip="删除"
                                  Command="{Binding $parent[UserControl].((vm:InstanceViewModel)DataContext).DeleteGroupCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="M19 4H15.5L14.5 3H9.5L8.5 4H5V6H19M6 19A2 2 0 0 0 8 21H16A2 2 0 0 0 18 19V7H6V19Z"
                                  Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource DangerBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <Border Grid.Row="2" Padding="12,10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Watermark="输入新分组名称" Text="{Binding NewGroupName}" FontSize="13"/>
              <Button Grid.Column="1" Content="创建" Margin="8,0,0,0" Padding="14,0"
                      Command="{Binding CreateGroupCommand}"/>
            </Grid>
          </Border>

        </Grid>
      </Border>
    </Border>

  </Panel>
</UserControl>
