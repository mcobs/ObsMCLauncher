<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ObsMCLauncher.Desktop.ViewModels"
             x:Class="ObsMCLauncher.Desktop.Views.MultiplayerView"
             x:DataType="vm:MultiplayerViewModel">

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="12"
            Padding="16"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}">
      <DockPanel>
        <Button Command="{Binding BackToModeSelectCommand}"
                Classes="ghost"
                IsVisible="{Binding IsInDetailView}"
                DockPanel.Dock="Left">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="M20 11H7.83L13.42 5.41L12 4L4 12L12 20L13.41 18.59L7.83 13H20V11Z" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="返回" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <TextBlock Text="多人联机"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="0,16,0,0" IsVisible="{Binding !IsInDetailView}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              CornerRadius="12"
              Padding="16"
              BorderThickness="1"
              BorderBrush="{DynamicResource BorderBrush}"
              Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="选择联机模式"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextBrush}"
                     Margin="0,0,0,6"/>
          <TextBlock Text="{Binding StatusText}"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
      </Border>

      <Grid Grid.Row="1"
            Margin="0,0,0,16"
            HorizontalAlignment="Center"
            ColumnDefinitions="260,16,260">
        <Button Grid.Column="0"
                Width="260"
                Height="160"
                Padding="18"
                CornerRadius="12"
                Classes="accent"
                Command="{Binding OpenHostPanelCommand}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
            <Path Data="M12 3L2 12H5V20H10V14H14V20H19V12H22L12 3Z" Width="40" Height="40" Stretch="Uniform" Fill="White" HorizontalAlignment="Center"/>
            <TextBlock Text="我要开房" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
            <TextBlock Text="分享你的本地服务器" FontSize="12" Opacity="0.85" HorizontalAlignment="Center" Foreground="White"/>
          </StackPanel>
        </Button>

        <Button Grid.Column="2"
                Width="260"
                Height="160"
                Padding="18"
                CornerRadius="12"
                Command="{Binding OpenJoinPanelCommand}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
            <Path Data="M16 11C17.66 11 19 9.66 19 8C19 6.34 17.66 5 16 5C14.34 5 13 6.34 13 8C13 9.66 14.34 11 16 11M8 11C9.66 11 11 9.66 11 8C11 6.34 9.66 5 8 5C6.34 5 5 6.34 5 8C5 9.66 6.34 11 8 11M8 13C5.33 13 0 14.34 0 17V20H16V17C16 14.34 10.67 13 8 13M16 13C15.71 13 15.38 13.02 15.03 13.05C16.33 13.89 17 15.02 17 17V20H24V17C24 14.34 18.67 13 16 13Z" Width="40" Height="40" Stretch="Uniform" Fill="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="加入房间" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="输入分享码加入" FontSize="12" Opacity="0.7" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
    </Grid>

    <Border Grid.Row="1"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="12"
            Padding="20"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}"
            Margin="0,16,0,0"
            IsVisible="{Binding IsInDetailView}">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Text="{Binding DetailTitle}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,16,*">
          <Grid Grid.Column="0">
            <StackPanel IsVisible="{Binding IsHostMode}">
              <TextBox Watermark="本地服务器端口 (默认 25565)"
                       Text="{Binding ServerPort}"
                       Margin="0,0,0,10"/>
              <Button Content="开始开房"
                      Classes="accent"
                      HorizontalAlignment="Stretch"
                      Command="{Binding StartServerCommand}"/>

              <Border Background="{DynamicResource SurfaceElevatedBrush}"
                      CornerRadius="8"
                      Padding="14"
                      Margin="0,12,0,0"
                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel Spacing="6">
                  <TextBlock Text="分享码" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <SelectableTextBlock Text="{Binding ShareCode}"
                                     FontSize="14"
                                     FontFamily="Consolas"
                                     Foreground="{DynamicResource TextBrush}"/>
                  <Button Content="复制分享码"
                          Classes="ghost"
                          HorizontalAlignment="Stretch"
                          Command="{Binding CopyShareCodeCommand}"
                          IsEnabled="{Binding HasShareCode}"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel IsVisible="{Binding !IsHostMode}">
              <TextBox Watermark="请输入分享码"
                       Text="{Binding JoinCode}"
                       Margin="0,0,0,10"/>
              <Button Content="加入房间"
                      Classes="accent"
                      HorizontalAlignment="Stretch"
                      Command="{Binding JoinRoomCommand}"/>
            </StackPanel>
          </Grid>

          <Border Grid.Column="2"
                  Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="14"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <TextBlock Text="运行输出"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="停止联机"
                        Classes="danger"
                        FontSize="12"
                        Command="{Binding StopLinkCommand}"
                        IsVisible="{Binding IsRunning}"/>
              </Grid>

              <ScrollViewer Grid.Row="1" Margin="0,8,0,0">
                <SelectableTextBlock Text="{Binding OutputLog}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"/>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
